POSTGRES_USER
POSTGRES_PASSWORD
POSTGRES_DB# ============================================================
#  Wine Quality Project — variáveis de ambiente
#  Copie este arquivo para .env e preencha os valores reais.
#  NUNCA commite o .env no repositório.
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=wine_db
POSTGRES_USER=wine_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# Construída automaticamente pelo docker-compose, mas útil
# para conexão local (ex: DBeaver, psql):
# DATABASE_URL=postgresql://wine_user:CHANGE_ME@localhost:5432/wine_db

# ── FastAPI ──────────────────────────────────────────────────
MODEL_PATH=mlp_wine.pkl      # caminho dentro do container
API_SECRET_KEY=CHANGE_ME_random_secret   # para autenticação futura (JWT)

# ── Streamlit ────────────────────────────────────────────────
API_URL=http://api:8000      # URL interna da rede Docker
                             # Para dev local: http://localhost:8000

# ── Ambiente ─────────────────────────────────────────────────
ENV=production               # development | production
LOG_LEVEL=INFO
