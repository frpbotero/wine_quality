# ============================================================
#  Wine Quality Project — Environment Variables
#  Copy to .env and fill in real values
#  NEVER commit .env to repository
# ============================================================

# ── Supabase (Wine Data Source) ──────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_anon_key_here

# ── PostgreSQL (if using local DB) ──────────────────────────
POSTGRES_DB=wine_db
POSTGRES_USER=wine_user
POSTGRES_PASSWORD=strong_password

# ── FastAPI ──────────────────────────────────────────────────
API_SECRET_KEY=your_secret_key_here
MODEL_PATH=models/best_model.pkl

# ── DagsHub / MLflow ─────────────────────────────────────────
# Create at: https://dagshub.com → Settings → Tokens
DAGSHUB_USERNAME=your_username
DAGSHUB_REPO_NAME=wine-quality
DAGSHUB_TOKEN=your_token_here

# ── MLflow Experiment ────────────────────────────────────────
MLFLOW_EXPERIMENT=wine-quality
MLFLOW_MODEL_NAME=wine-quality

# ── Render/Production ────────────────────────────────────────
PORT=8501
ENVIRONMENT=production
