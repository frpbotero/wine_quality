# ============================================================
#  Wine Quality Project — Environment Variables
#  Copy to .env and fill in real values
#  NEVER commit .env to repository
# ============================================================

# ── Supabase (source + logging) ──────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_anon_or_service_key_here
SUPABASE_TABLE=wine_quality
SUPABASE_PREDICTIONS_TABLE=wine_predictions

# Postgres URL for table creation/seed (Supabase DB)
# You can use either SUPABASE_DATABASE_URL or SUPABASE_DB_URL
SUPABASE_DATABASE_URL=postgresql://user:password@host:5432/postgres
SUPABASE_DB_URL=

# ── Database (FastAPI local log + ingestion fallback SQL) ────
DATABASE_URL=postgresql://wine_user:wine_pass@localhost:5432/wine_db

# ── API / UI ──────────────────────────────────────────────────
MODEL_PATH=models/best_model.pkl
API_SECRET_KEY=change_me_if_used

# ── DagsHub / MLflow ─────────────────────────────────────────
# Create token at: https://dagshub.com → Settings → Tokens
DAGSHUB_USERNAME=your_username
DAGSHUB_REPO_NAME=wine-predict
DAGSHUB_TOKEN=your_token_here
MLFLOW_EXPERIMENT=wine-predict
# Used by API registry loading (default in main.py: wine-predict-binary)
MLFLOW_MODEL_NAME=wine-predict-binary
# Optional explicit tracking URI; leave empty to use fallback in code
MLFLOW_TRACKING_URI=

# ── Ingestion behavior ────────────────────────────────────────
ALLOW_LOCAL_FALLBACK=false

# Optional (Kaggle CLI download in ingestion.py)
KAGGLE_USERNAME=
KAGGLE_KEY=

# ── Render/Production ────────────────────────────────────────
PORT=8501
ENVIRONMENT=production
